# Dependências
b_frontend/node_modules/

# Build
b_frontend/dist/

# Python
a_backend/venv/
a_backend/__pycache__/
a_backend/**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Variáveis de ambiente (contém chaves secretas)
a_backend/.env

# Arquivos de upload dos usuários
c_data/*
!c_data/.gitkeep

# ChromaDB — banco vetorial local (gerado automaticamente)
chroma_db/

# Cache do modelo sentence-transformers (baixado automaticamente pelo HuggingFace)
# O modelo fica em ~/.cache/huggingface/ — não precisa ser commitado

# Logs
*.log
npm-debug.log*

# Testes / cobertura
.pytest_cache/
htmlcov/
.coverage

# IDEs e editores
.vscode/
.idea/
*.swp
*.swo
*~

# Sistema operacional
.DS_Store
Thumbs.db
ehthumbs.db
